# =============================================================================
# Enterprise RAG System - .gitignore
# =============================================================================

# --- Environment & Secrets ---
.env
.env.*
!.env.example
*.pem
*.key

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl
MANIFEST

# --- Virtual Environments ---
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# --- IDEs & Editors ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# --- Testing & Coverage ---
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.log

# --- Vector Database (large, local) ---
data/chroma_db/
data/processed/
data/crawl_logs/
data/eval_results/

# --- Raw Documents (may be proprietary) ---
# Uncomment below if raw docs should NOT be pushed:
# data/raw/

# --- Jupyter Notebooks ---
.ipynb_checkpoints/
*.ipynb

# --- Model Cache (large files) ---
.cache/
models/
*.bin
*.pt
*.safetensors
sentence_transformers/

# --- Temporary & Scratch Files ---
tmp/
temp/
*.tmp
*.bak
_scratch/

# --- OS Files ---
.DS_Store
ehthumbs.db
[Dd]esktop.ini
Thumbs.db

# --- Playwright Browser Binaries ---
playwright-cache/

# --- BMad Agent Internal Files ---
.agent/
.gemini/
.claude/
_bmad/
_bmad-output/

# --- Logs ---
logs/
*.log
log/

# --- Ignore Specific Files ---
rag.py
docs/
