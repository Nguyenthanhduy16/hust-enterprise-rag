# =============================================================================
# Enterprise RAG System - Environment Variables Example
# Copy file này thành .env và điền giá trị thực
# =============================================================================

# LLM Providers (cấu hình ít nhất một)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
OPENAI_API_KEY=sk-your-openai-key-here
GOOGLE_API_KEY=AIza-your-google-key-here

# Default LLM Provider (anthropic | openai | google)
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_MODEL=claude-3-5-sonnet-20241022

# Embedding (local, không cần API key)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ChromaDB (local storage path)
CHROMA_DB_PATH=./data/chroma_db
CHROMA_COLLECTION_NAME=regulatory_docs

# API Server
API_HOST=0.0.0.0
API_PORT=8000
